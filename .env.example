# Example environment variables for misc_tools

# For backup_phone.py (can specify multiple destinations)
# Example: BACKUP_DESTINATION_1=D:\\Backups\\Pixel6a_1
#          BACKUP_DESTINATION_2=D:\\Backups\\Pixel6a_2
BACKUP_DESTINATION_1=D:/downloads/Backup-Pixel6a

# For cmd/backup (Go tool)
# Source directory on local filesystem to copy from
BACKUP_SOURCE=D:/source
# Destination directory on local filesystem to copy to
BACKUP_DEST=D:/backup
# Transfer rate limit in MB/s (0 = unlimited)
TRANSFER_RATE_MB=50

# For bw_duplicate_entries.py
# Comma-separated list of search strings to highlight in passwords
SEARCH_STRINGS=password,1234,secret

# Notes:
# - Use Windows-style paths with double backslashes (\\) or forward slashes (/).
# - You can define multiple BACKUP_DESTINATION_N variables for backup_phone.py.
